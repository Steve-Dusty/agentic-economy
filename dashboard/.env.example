# Nevermined API key (get from https://nevermined.app)
NVM_API_KEY=sandbox:YOUR_API_KEY_HERE
NVM_ENVIRONMENT=sandbox

# Your wallet address (from Nevermined dashboard)
USDC_WALLET=0xYOUR_WALLET_ADDRESS

# Agent and plan IDs (from agent registration)
NVM_AGENT_ID_CRYPTO=YOUR_AGENT_ID
NVM_PLAN_ID_CRYPTO=YOUR_CRYPTO_PLAN_ID
NVM_PLAN_ID_FREE=YOUR_FREE_PLAN_ID
NVM_BUYER_AGENT_ID=YOUR_BUYER_AGENT_ID
